# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must never be committed.
#
# Get an API key at: https://www.zotero.org/settings/keys
# Your library ID (userID) is shown on that same settings page.

ZOTERO_API_KEY=your_api_key_here
ZOTERO_LIBRARY_ID=0000000
ZOTERO_LIBRARY_TYPE=user

# Optional: a contact email puts Crossref requests in the faster "polite pool".
# CROSSREF_MAILTO=you@example.com
